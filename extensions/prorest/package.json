      {
        "input": "@prorest restart all node processes",
        "mocks": {
          "restartall-process": {
            "success": true,
            "message": "Restarted all \"node\" processes"
          }
        },
        "expected": [
          {
            "callsTool": {
              "name": "restartall-process",
              "arguments": {
                "processName": "node"
              }
            }
          },
          {
            "meetsCriteria": "Restarts all node processes using the restartall tool"
          }
        ]
      },
      {
        "input": "@prorest force restart all Google Chrome Helper processes",
        "mocks": {
          "restartall-process": {
            "success": true,
            "message": "Restarted all \"Google Chrome Helper\" processes"
          }
        },
        "expected": [
          {
            "callsTool": {
              "name": "restartall-process",
              "arguments": {
                "processName": "Google Chrome Helper",
                "force": true
              }
            }
          },
          {
            "meetsCriteria": "Force restarts all Google Chrome Helper processes using elevated privileges"
          }
        ]
      }
    ]
  },
  "preferences": [
    {
      "description": "Refresh the list every N ms. Use 0 to disable. Minimum: 1000.",
      "label": "Interval (ms)",
      "name": "refreshDuration",
      "required": false,
      "title": "Auto-Refresh",
      "type": "textfield",
      "default": "3000",
      "placeholder": "3000"
    },
    {
      "description": "Search in the full executable path.",
      "label": "Search Process Paths",
      "name": "shouldSearchInPaths",
      "required": false,
      "default": false,
      "title": "Search",
      "type": "checkbox"
    },
    {
      "description": "Search in the PID.",
      "label": "Search Process PID",
      "name": "shouldSearchInPid",
      "required": false,
      "default": false,
      "title": "",
      "type": "checkbox"
    },
    {
      "description": "List app processes before other results.",
      "label": "Prioritize Apps",
      "name": "shouldPrioritizeAppsWhenFiltering",
      "required": false,
      "default": false,
      "title": "",
      "type": "checkbox"
    },
    {
      "description": "Show process PID info.",
      "label": "Show PID",
      "name": "shouldShowPID",
      "required": false,
      "default": false,
      "title": "Display",
      "type": "checkbox"
    },
    {
      "description": "Show process path.",
      "label": "Show Process Path",
      "name": "shouldShowPath",
      "required": false,
      "default": false,
      "title": "",
      "type": "checkbox"
    },
    {
      "description": "Close window after restarting a process.",
      "label": "Close Window",
      "name": "closeWindowAfterRestart",
      "required": false,
      "default": true,
      "title": "After Restarting",
      "type": "checkbox"
    },
    {
      "description": "Clear search bar after restarting a process.",
      "label": "Clear Search Bar",
      "name": "clearSearchBarAfterRestart",
      "required": false,
      "default": true,
      "title": "",
      "type": "checkbox"
    },
    {
      "description": "Go back to root search after restarting a process.",
      "label": "Go Back to Root Search",
      "name": "goToRootAfterRestart",
      "required": false,
      "default": false,
      "title": "",
      "type": "checkbox"
    },
    {
      "description": "Skip confirmation dialogs when restarting processes.",
      "label": "Never Ask for Confirmation",
      "name": "skipConfirmation",
      "required": false,
      "default": false,
      "title": "Confirmation",
      "type": "checkbox"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.1",
    "pretty-bytes": "^7.1.0"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "22.13.10",
    "@types/react": "19.0.10",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build -e dist",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
